# =============================================================================
# KALBI-2: Autonomous Multi-Agent Trading System
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# =============================================================================

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...
OLLAMA_BASE_URL=http://localhost:11434

# --- Trading: Kalshi ---
KALSHI_API_KEY_ID=your-kalshi-api-key-id
KALSHI_PRIVATE_KEY_PATH=./private_key.pem

# --- Trading: Alpaca ---
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- News & Data ---
NEWSAPI_KEY=your-newsapi-key
SERPER_API_KEY=your-serper-api-key
POLYGON_API_KEY=your-polygon-api-key
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret

# --- Infrastructure ---
TIMESCALEDB_URL=postgresql://kalbi2:kalbi2_secure_password@localhost:5432/kalbi2
REDIS_URL=redis://localhost:6379/0

# --- Notifications ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
DISCORD_WEBHOOK_URL=

# --- Risk Controls ---
MAX_DAILY_LOSS_PCT=5.0
MAX_POSITION_PCT=2.0
MAX_PORTFOLIO_DEPLOYED_PCT=50.0
MAX_CORRELATION=0.7
PAPER_TRADING_MODE=true

# --- Scheduling ---
KALSHI_SCAN_INTERVAL_MIN=15
EQUITIES_SCAN_INTERVAL_MIN=30
META_REVIEW_INTERVAL_MIN=120
